<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off" internalLogFile="c:\temp\nlog-internal.log">

	<!-- 檔案位置 -->
	<variable name="LogTxtLocation" value="${basedir}/Logs/${shortdate}.log"/>

	<!-- 寫入目標-->
	<targets async="true">
		<!--<target xsi:type="File" name="logFile" fileName="${LogTxtLocation}"
					layout="${longdate} ${uppercase:${level}} ${message}" />-->
		
		<target xsi:type="File"	name="Tracelog" 
				fileName="${basedir}/logs/Trace/${date:format=yyyy-MM-dd}.log"  
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />
		
		<target xsi:type="File" name="Debuglog"
				fileName="${basedir}/logs/Debug/${date:format=yyyy-MM-dd}.log"
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />
		
		<target xsi:type="File"	name="Infolog"
				fileName="${basedir}/logs/Info/${date:format=yyyy-MM-dd}.log"
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />
		
		<target xsi:type="File"	name="Warnlog"
				fileName="${basedir}/logs/Warn/${date:format=yyyy-MM-dd}.log"
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />
		
		<target xsi:type="File"	name="Errorlog"
				fileName="${basedir}/logs/Error/${date:format=yyyy-MM-dd}.log"
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />

		<target xsi:type="File"	name="Offlog"
				fileName="${basedir}/logs/Off/${date:format=yyyy-MM-dd}.log"
				archiveEvery="Day"
				layout="${longdate}–${uppercase:${level}}–${message}" />
	</targets>

	<!-- 紀錄規則-->
	<rules>
		<!--<logger name="*" minlevel="Debug" writeTo="logFile" />-->
		<logger name="*" level="Trace" writeTo="Tracelog" />
		<logger name="*" minlevel="Debug" writeTo="Debuglog" />
		<logger name="*" minlevel="Info" writeTo="Infolog" />
		<logger name="*" minlevel="Warn" writeTo="Warnlog" />
		<logger name="*" minlevel="Error" writeTo="Errorlog" />
		<logger name="*" minlevel="Fatal" writeTo="Fatallog" />
		<logger name="*" minlevel="Off" writeTo="Offlog" />
	</rules>
</nlog>