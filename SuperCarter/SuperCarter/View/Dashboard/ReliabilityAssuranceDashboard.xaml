<UserControl x:Class="SuperCarter.View.Dashboard.ReliabilityAssuranceDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SuperCarter.View.Dashboard"
             xmlns:SpyderToggle="clr-namespace:Spyder.Controls.Toggle;assembly=Spyder.Controls.Toggle" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:xrpb="clr-namespace:XamlRadialProgressBar;assembly=XamlRadialProgressBar"  
           
             mc:Ignorable="d" 
            >
    <Grid>
        <Grid.Resources>
            <Style TargetType="Label" x:Key="DashboardLabel">
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="Console"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>
        <ScrollViewer Grid.Row="1"  VerticalScrollBarVisibility="Visible"  Margin="0 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="390"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="1" Margin="5">


                    </Grid>
                    <Grid Grid.Column="0" Margin="8">
                        <!--此網格為前端物件的項目-->
                        <Grid>
                            <Border  Background="White" CornerRadius="5">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                              ShadowDepth = "0" 
                                              BlurRadius = "3" 
                                              Opacity = "3" 
                                              Direction = "0"                                  
                                              />
                                </Border.Effect>
                                <Border.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Border Background="Black"
                                            SnapsToDevicePixels="True"
                                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
                                            />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.OpacityMask>
                                <Grid  Background="#FFE0E0E0" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" MinHeight="37" MaxHeight="42"/>
                                        <RowDefinition Height="5*" />

                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" VerticalAlignment="Bottom" >

                                    </Grid>
                                    <Grid Grid.Row="1" Background="White"/>
                                </Grid>

                            </Border>
                        </Grid>
                        <!--此網格為後端物件的項目-->
                        <Grid >
                            <Grid.Resources>
                                <Style x:Key="TextBlockstyle" TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Cascadia Mono PL SemiBold"/>
                                    <Setter Property="Margin" Value="0 0 0 0" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"  MinHeight="37" MaxHeight="42"/>
                                <RowDefinition Height="5*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" VerticalAlignment="Center" >
                                <TextBlock VerticalAlignment="Center"
                                           Margin="13 0 0 0"  
                                           FontFamily="Console" 
                                           FontSize="14"
                                           >Setting</TextBlock>

                            </Grid>
                            <ScrollViewer Name="ScheduleParametersSet" Grid.Row="1"
                                          VerticalScrollBarVisibility="Visible" 
                                          Margin="0 0" Height="320"
                                             >
                                <StackPanel Grid.Row="1" Margin="6">

                                    <ListBox    ScrollViewer.CanContentScroll="True"   >
                                        <ListBox.Resources>
                                            <Style TargetType="{x:Type Expander}">
                                                <Setter Property="IsExpanded"
                                                    Value="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"/>
                                            </Style>
                                        </ListBox.Resources>
                                        <ListBox.Template>
                                            <ControlTemplate TargetType="{x:Type ListBox}">
                                                <ItemsPresenter/>
                                            </ControlTemplate>
                                        </ListBox.Template>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <ContentPresenter Content="{TemplateBinding Content}"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <!--目前有關運行的相關功能
                                            ================================================================
                                            1. T0 資料的蒐集與報告的產出
                                        
                                            2. 發送端的腳本輸出
                                                
                                        -->
                                        <TabControl  TabStripPlacement="Top" Margin="1" >
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal" Width="156">
                                                        <materialDesign:PackIcon Kind="Numeric1CircleOutline"
                                                             Width="26" Height="32"
                                                             VerticalAlignment="Stretch" 
                                                             Foreground="#FF4D4D4D" 
                                                             HorizontalAlignment="Stretch"
                                                             />
                                                        <TextBlock Text="Dynamic monitor" Foreground="Black" 
                                                                FontWeight="Bold" Margin="1 5"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <StackPanel Orientation="Vertical">
                                                    <Expander Background="#FFDDDDDD"  IsExpanded="True" Margin="5">
                                                        <Expander.Header>
                                                            <BulletDecorator>
                                                                <BulletDecorator.Bullet>
                                                                    <materialDesign:PackIcon Grid.Row="0" 
                                                                                Kind="TuneVerticalVariant"
                                                                                Width="22" Height="42"
                                                                                VerticalAlignment="Stretch" 
                                                                                Foreground="Black" 
                                                                                HorizontalAlignment="Stretch"/>
                                                                </BulletDecorator.Bullet>
                                                                <TextBlock Margin="10,0,0,0" Text="" 
                                                                       FontFamily="Console" 
                                                                       FontSize="14"
                                                                       VerticalAlignment="Center" 
                                                                       HorizontalAlignment="Stretch"
                                                                       Foreground="Black"  />
                                                            </BulletDecorator>
                                                        </Expander.Header>
                                                        <WrapPanel  Background="White"  >
                                                            <StackPanel Orientation="Vertical" Margin ="0 0 0 0" Width="320">
                                                                <Label  Content="選取運行的腳本 : "   Margin="0" HorizontalAlignment="Left"/>
                                                                <StackPanel  Orientation="Vertical" Margin ="0">

                                                                    <TextBox x:Name="SDMChecklistscriptXMLPath"
                                                                         TextWrapping="Wrap"
                                                                         FontSize="14" 
                                                                         Height="50"
                                                                         Text="{Binding CustomScriptEditor.SDMChecklistscriptXMLPath}"
                                                                         IsEnabled="{Binding IsUnlockScriptSetting}"
                                                                         FontFamily="Champagne &amp;amp; Limousines"
                                                                         TextChanged="SDMChecklistscriptXMLPath_TextChanged"
                                                                             />

                                                                    <Button Width="300" Height="33" 
                                                                        Command="{Binding CustomScriptEditor.LoadSDMchecklistScript}"  
                                                                        IsEnabled="{Binding IsUnlockScriptSetting}"
                                                                        ToolTip="View the path location" 
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Center" 
                                                                        Margin="3">

                                                                        <Button.Style>

                                                                            <Style TargetType="{x:Type Button}">
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                                                            <ContentControl>
                                                                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .9 1.0 1.1" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                                                                        <materialDesign:PackIcon Kind="OpenInNew"
                                                                                                                        Width="23" Height="23"
                                                                                                                        VerticalAlignment="Stretch" 
                                                                                                                        Foreground="#FF4D4D4D" 
                                                                                                                        HorizontalAlignment="Stretch"/>
                                                                                                        <Label Content="Open" VerticalAlignment="Center" Foreground="Black"/>
                                                                                                    </StackPanel>
                                                                                                </Border>
                                                                                            </ContentControl>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </StackPanel>

                                                            </StackPanel>
                                                        </WrapPanel>
                                                    </Expander>
                                                    <Border  Background="White" CornerRadius="6" Margin="6 6 6 3">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" 
			                                                ShadowDepth = "0" 
			                                                BlurRadius = "3" 
			                                                Opacity = "1" 
			                                                Direction = "0"                                 
			                                                      />
                                                        </Border.Effect>
                                                        <Border.OpacityMask>
                                                            <VisualBrush>
                                                                <VisualBrush.Visual>
                                                                    <Border Background="Black"
					                                            SnapsToDevicePixels="True"
					                                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            />
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Border.OpacityMask>
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Label Name="DisplayLbl" Visibility="{Binding CustomScriptEditor.DisplaySwitch}" FontSize="19"
                                                               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8 0 0 0"
                                                               Content="{Binding CustomScriptEditor.LabelText}" Foreground="{Binding CustomScriptEditor.ForeColor}" />

                                                            <SpyderToggle:RoundToggleButton 
                                                                IsChecked="{Binding CustomScriptEditor.IsEnableExecuteSDMchecklists, Mode=TwoWay}"
                                                                Command="{Binding CustomScriptEditor.ExecuteSDMchecklistScript}"
                                                                MaxHeight="29"
                                                                Margin="6"
                                                                HorizontalAlignment="Right"
                                                                 />
                                                            <TextBlock Text="運行" Margin="12 0"
                                                                   VerticalAlignment="Center"
                                                                   />

                                                        </WrapPanel>
                                                    </Border>
                                                    <Button Width="300" Height="33"
                                                        Command="{Binding CustomScriptEditor.SaveDynamicMonitorresult}"  
                                                        IsEnabled="{Binding IsUnlockScriptSetting}"
                                                        ToolTip="View the path location" 
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center" 
                                                        Margin="3 ">

                                                        <Button.Style>

                                                            <Style TargetType="{x:Type Button}">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                                            <ContentControl>
                                                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .9 1.0 1.1" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                                                        <materialDesign:PackIcon Kind="ContentSave"
                                                                                                                        Width="23" Height="23"
                                                                                                                        VerticalAlignment="Stretch" 
                                                                                                                        Foreground="#FF4D4D4D" 
                                                                                                                        HorizontalAlignment="Stretch"/>
                                                                                        <Label Content="Save" VerticalAlignment="Center" Foreground="Black"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </ContentControl>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>

                                            </TabItem>
                                            <TabItem>
                                                <TabItem.Header>
                                                    <StackPanel Orientation="Horizontal"  Width="156">
                                                        <materialDesign:PackIcon Kind="Numeric2CircleOutline"
                                                             Width="26" Height="32"
                                                             VerticalAlignment="Stretch" 
                                                             Foreground="#FF4D4D4D" 
                                                             HorizontalAlignment="Stretch"
                                                             />
                                                        <TextBlock Text="Scheduled Detection" Foreground="Black" 
                                                               FontWeight="Bold" Margin="1 5"/>
                                                    </StackPanel>
                                                </TabItem.Header>
                                                <StackPanel Orientation="Vertical" >
                                                    <Expander  IsExpanded="True" Margin="5" Background="#FFDDDDDD">
                                                        <Expander.Header>
                                                            <BulletDecorator>
                                                                <BulletDecorator.Bullet>
                                                                    <materialDesign:PackIcon Grid.Row="0" 
                                                                                Kind="TuneVerticalVariant"
                                                                                Width="22" Height="42"
                                                                                VerticalAlignment="Stretch" 
                                                                                Foreground="Black" 
                                                                                HorizontalAlignment="Stretch"/>
                                                                </BulletDecorator.Bullet>
                                                                <TextBlock Margin="10,0,0,0" Text="" 
                                                                       FontFamily="Console" 
                                                                       FontSize="14"
                                                                       VerticalAlignment="Center" 
                                                                       HorizontalAlignment="Stretch"
                                                                       Foreground="Black"  />
                                                            </BulletDecorator>
                                                        </Expander.Header>
                                                        <WrapPanel  Background="White"  >
                                                            <StackPanel Orientation="Vertical" Margin ="0 0 0 0" Width="330">
                                                                <Label  Content="選取運行的腳本 : "   Margin="0" HorizontalAlignment="Left"/>
                                                                <StackPanel  Orientation="Vertical" Margin ="0">


                                                                    <StackPanel  Orientation="Horizontal" Margin ="0">
                                                                        <TextBox x:Name="ScheduleScrollingScriptPath"
                                                                             TextWrapping="Wrap"
                                                                             Height="50"
                                                                             FontSize="14"
                                                                             MinWidth="300"
                                                                             Text="{Binding ScheduleScrollingScriptPath}"
                                                                             IsEnabled="{Binding IsUnlockScriptSetting}"
                                                                             FontFamily="Champagne &amp;amp; Limousines"
                                                                             TextChanged="ScheduleScrollingScriptPath_TextChanged"/>

                                                                    </StackPanel>
                                                                    <Button Width="310" Height="33" 
                                                                        Command="{Binding LoadScheduleScrollingScript}"  
                                                                        IsEnabled="{Binding IsUnlockScriptSetting}"
                                                                        ToolTip="View the path location" 
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Center" 
                                                                        Margin="3 ">

                                                                        <Button.Style>

                                                                            <Style TargetType="{x:Type Button}">
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                                                            <ContentControl>
                                                                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .7 1.0 1.1" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                                                                        <materialDesign:PackIcon Kind="OpenInNew"
                                                                                                                        Width="23" Height="23"
                                                                                                                        VerticalAlignment="Stretch" 
                                                                                                                        Foreground="#FF4D4D4D" 
                                                                                                                        HorizontalAlignment="Stretch"/>
                                                                                                        <Label Content="Open" VerticalAlignment="Center" Foreground="Black"/>
                                                                                                    </StackPanel>
                                                                                                </Border>
                                                                                            </ContentControl>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>


                                                                </StackPanel>

                                                            </StackPanel>
                                                        </WrapPanel>
                                                    </Expander>
                                                    <Border  Background="White" CornerRadius="6" Margin="6 0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" 
			                                                ShadowDepth = "0" 
			                                                BlurRadius = "3" 
			                                                Opacity = "1" 
			                                                Direction = "0"                                 
			                                                      />
                                                        </Border.Effect>
                                                        <Border.OpacityMask>
                                                            <VisualBrush>
                                                                <VisualBrush.Visual>
                                                                    <Border Background="Black"
					                                            SnapsToDevicePixels="True"
					                                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
					                                            />
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Border.OpacityMask>
                                                        <WrapPanel Orientation="Horizontal">

                                                            <SpyderToggle:RoundToggleButton IsChecked="{Binding IsEnableExecuteScheduleScrolling, Mode=TwoWay}"
                                                                                Command="{Binding ExecuteScriptScroling}"
                                                                                MaxHeight="29"
                                                                                Margin="6"
                                                                                HorizontalAlignment="Right"
                                                                                 />
                                                            <TextBlock Text="運行" Margin="12 0"
                                                                   VerticalAlignment="Center"
                                                                   />

                                                        </WrapPanel>
                                                    </Border>

                                                </StackPanel>


                                            </TabItem>
                                        </TabControl>

                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>

                        </Grid>
                    </Grid>
                    <Grid Grid.Column="1" Margin="7" MinWidth="300" MaxWidth="400">
                        <!--此網格為前端物件的項目-->
                        <Grid>
                            <Border  Background="White" CornerRadius="5">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" 
                                                      ShadowDepth = "0" 
                                                      BlurRadius = "3" 
                                                      Opacity = "3" 
                                                      Direction = "0"                                  
                                                      />
                                </Border.Effect>
                                <Border.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Border Background="Black"
                                                    SnapsToDevicePixels="True"
                                                    CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
                                                    />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.OpacityMask>
                                <Grid  Background="#FFE0E0E0" >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="5*" />
                                        <RowDefinition Height="40"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="1" VerticalAlignment="Bottom" >

                                    </Grid>
                                    <Grid Grid.Row="0" Background="White"/>
                                </Grid>

                            </Border>
                        </Grid>
                        <!--此網格為後端物件的項目-->
                        <Grid >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="5*" />
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="1" VerticalAlignment="Center" >
                                <TextBlock VerticalAlignment="Center"
                                           Margin="13 0 0 0"  
                                           FontFamily="Console" 
                                           FontSize="14"
                                           >Super Carrier Board</TextBlock>
                            </Grid>
                            <Grid Grid.Row="0" Margin="0 0 0 7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" >
                                    <Grid.ColumnDefinitions >
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <xrpb:RadialProgressBar Value="{Binding Customscript.PercentLoopValue}"	  VerticalAlignment="Center" HorizontalAlignment="Center" 
                                            Margin="0"
                                            ArcRotationDegree="270" ArcDirection="Clockwise"
                                            Foreground="#FF005087" InnerBackgroundBrush="White"
                                            ArcWidth="20"
                                            Width="200" Height="200"
                                            />
                                        <!--<xrpb:RadialProgressBar Value="{Binding PercentLoopValue, UpdateSourceTrigger=PropertyChanged}"	  VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                Margin="0"
                                        ArcRotationDegree="270" ArcDirection="Clockwise"
                                        Foreground="#FF005087" InnerBackgroundBrush="White"
                                        ArcWidth="20"
                                        Width="170" Height="170"
                                        />-->
                                        <!--<xrpb:RadialProgressBar Value="82" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                Margin="0"
                                        ArcRotationDegree="270" ArcDirection="Clockwise"
                                        Foreground="#FF005087" InnerBackgroundBrush="White"
                                        ArcWidth="20"
                                        Width="170" Height="170"
                                        />-->

                                        <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                                            <!--<TextBlock Text="82%" 
                               FontFamily="Lucida Console"
                               FontSize="27"
                               />-->

                                            <TextBlock Text="{Binding Customscript.strLoopValue}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontFamily="Lucida Console"
                                   FontSize="36"/>

                                        </StackPanel>
                                    </Grid>
                                    <Grid Grid.Column="1" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 0" Height="70">
                                                <TextBlock Text="loop:" Grid.Row="0"
                                                               Margin="0"
                                                               VerticalAlignment="Bottom" 
                                                               HorizontalAlignment="Center"
                                                               FontFamily="Lucida Console"
                                                               FontSize="16"/>
                                            </Grid>

                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 0" Height="60">
                                                <WrapPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Customscript.CurLoopValue}"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    FontFamily="Lucida Console"  
                                                                    FontSize="14"/>
                                                    <Separator/>
                                                    <TextBlock Text="{Binding Customscript.Fullloop , Mode=TwoWay}" 
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    FontFamily="Lucida Console" 
                                                                    FontSize="14"/>
                                                </WrapPanel>
                                            </Grid>

                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 0" Height="60">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Text="phase:" Grid.Row="0"
                                                               Margin="0"
                                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                                               FontFamily="Lucida Console"
                                                               FontSize="14"/>
                                                    <Label Content="{Binding Customscript.Curphase}" Style ="{StaticResource DashboardLabel}"/>

                                                </StackPanel>
                                            </Grid>
                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 0" Height="60">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Text="sub-phase:" Grid.Row="0"
                                                               Margin="0"
                                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                                               FontFamily="Lucida Console"
                                                               FontSize="14"/>
                                                    <Label Content="{Binding Customscript.subloop}" Style ="{StaticResource DashboardLabel}"/>

                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="1" Margin="7">
                    <!--此網格為前端物件的項目-->
                    <Grid>
                        <Border  Background="White" CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" 
                                                                ShadowDepth = "0" 
                                                                BlurRadius = "3" 
                                                                Opacity = "3" 
                                                                Direction = "0"                                  
                                                                />
                            </Border.Effect>
                            <Border.OpacityMask>
                                <VisualBrush>
                                    <VisualBrush.Visual>
                                        <Border Background="Black"
                                                                SnapsToDevicePixels="True"
                                                                CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                />
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Border.OpacityMask>
                            <Grid  Background="#FFE0E0E0" >
                                <Grid.RowDefinitions>

                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="5*" />

                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" VerticalAlignment="Bottom" >

                                </Grid>
                                <Grid Grid.Row="1" Background="White" />
                            </Grid>

                        </Border>
                    </Grid>
                    <!--此網格為後端物件的項目-->
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
