<UserControl x:Class="SuperCarter.View.Dashboard.UserScriptEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SuperCarter.View.Dashboard"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:self="clr-namespace:SuperCarter.Model"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid  Margin="5" >
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <WrapPanel Orientation="Horizontal" Margin="0"  HorizontalAlignment="Left" >
                    <Button Width="95" Height="33" 
                            Command="{Binding scriptEditor.ReleasetoRefresh}"                                             
                            ToolTip="View the path location" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" 
                            Margin="50 0 50 0">

                        <Button.Style>

                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <ContentControl>
                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .7 1.0 1.2" Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                        <materialDesign:PackIcon Kind="Refresh"
                                                                            Width="23" Height="23"
                                                                            VerticalAlignment="Stretch" 
                                                                            Foreground="#FF4D4D4D" 
                                                                            HorizontalAlignment="Stretch"/>
                                                        <Label Content="Refresh" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ContentControl>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="95" Height="33" 
                            Command="{Binding Loadblockscript }"                                             
                            ToolTip="View the path location" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" 
                            Margin="3 0 3 0">

                        <Button.Style>

                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <ContentControl>
                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .7 1.0 1.2" Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                        <materialDesign:PackIcon Kind="FolderOpenOutline"
                                                                            Width="23" Height="23"
                                                                            VerticalAlignment="Stretch" 
                                                                            Foreground="#FF4D4D4D" 
                                                                            HorizontalAlignment="Stretch"/>
                                                        <Label Content="Load" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ContentControl>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Width="95" Height="33" 
                            Command="{Binding scriptEditor.SaveBlockprocedure}"                                             
                            ToolTip="View the path location" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" 
                            Margin="3 0 3 0">

                        <Button.Style>

                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <ContentControl>
                                                <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.0 .7 1.0 1.2" Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal" Margin="9 0 0 0">
                                                        <materialDesign:PackIcon Kind="ContentSaveOutline"
                                                                            Width="23" Height="23"
                                                                            VerticalAlignment="Stretch" 
                                                                            Foreground="#FF4D4D4D" 
                                                                            HorizontalAlignment="Stretch"/>
                                                        <Label Content="Save" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ContentControl>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Button.IsPressed" Value="True" >
                                                    <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                    <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </WrapPanel>

            </Grid>
            <Grid Grid.Row="1" VerticalAlignment="Stretch" >


                <!--此網格為前端物件的項目-->
                <Grid>
                    <Border  Background="White" CornerRadius="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" 
                                              ShadowDepth = "0" 
                                              BlurRadius = "3" 
                                              Opacity = "3" 
                                              Direction = "0"                                  
                                              />
                        </Border.Effect>
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border Background="Black"
                                            SnapsToDevicePixels="True"
                                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
                                            />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Grid  Background="White" >

                        </Grid>

                    </Border>
                </Grid>
                <!--此網格為後端物件的項目-->
                <Grid >
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>

                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <ScrollViewer Name="scrollViewer" Grid.Column="0"  DockPanel.Dock="Left" MinWidth="800"
                                           VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          MinHeight="800"
                                          VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible" >
                                <Grid >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="31"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="1*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBox x:Name="CurrentBlockscriptfile" Text="{Binding scriptEditor.Openblockfilepath}" IsReadOnly="True" TextChanged="CurrentBlockscriptfile_TextChanged" Margin="7" Background="LightSlateGray"/>
                                    </Grid>
                                    <Grid  Grid.Row="1">
                                        <WrapPanel Orientation="Vertical"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="5 0 5 0" 
                                           >
                                            <StackPanel Orientation="Horizontal" >
                                                <Label Content="Time (min):" 
                                                HorizontalAlignment="Center"/>
                                                <Label Content="{Binding scriptEditor.Estimateruntimefullblock}" HorizontalAlignment="Center"/>
                                            </StackPanel >
                                            <Separator Margin="2"/>

                                            <StackPanel Orientation="Horizontal" >
                                                <Label Content="Loop" 
                                               HorizontalAlignment="Center"/>
                                                <TextBox Text="{Binding scriptEditor.Fullloop}" MinWidth="70" />
                                            </StackPanel >

                                        </WrapPanel>
                                        <Separator Margin="12 0 12 0" VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <Grid  Grid.Row="2"  VerticalAlignment="Stretch" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" MinWidth="240"/>
                                            <ColumnDefinition Width="1*" MinWidth="240"/>
                                            <ColumnDefinition Width="1*" MinWidth="240"/>
                                            <ColumnDefinition Width="1*" MinWidth="240"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Margin="5">
                                            <WrapPanel Orientation="Vertical" 
                                                HorizontalAlignment="Center" >
                                                <Label Content="A" 
                                        HorizontalAlignment="Center"/>
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Time (min):" 
                                            HorizontalAlignment="Center"/>
                                                    <Label Content="{Binding scriptEditor.EstimateruntimeforblockA}" 
                                            HorizontalAlignment="Center"/>
                                                </StackPanel >
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Loop" 
                                            HorizontalAlignment="Center"/>
                                                    <TextBox Text="{Binding scriptEditor.ExecuteBlockALoop}" MinWidth="70"/>
                                                </StackPanel>

                                                <Label Content="Script delay (ms):" />
                                                <Label Content="{Binding scriptEditor.blockAscriptDelaytime}"/>
                                                <Button Command="{Binding scriptEditor.LoadscripttoBlockA}" Height="23" Content="Load"></Button>
                                                <TextBox Text="{Binding scriptEditor.blockAscriptpath, Mode=TwoWay}"
                                                 TextWrapping="WrapWithOverflow"   IsReadOnly="True"
                                                 MaxWidth="220"
                                                 />
                                                <Label Content="sequence count : "/>
                                                <Label Content="{Binding scriptEditor.blockAitemcount}"/>
                                            </WrapPanel>
                                        </Grid>
                                        <Grid Grid.Column="1" Margin="5" >
                                            <WrapPanel Orientation="Vertical"
                                HorizontalAlignment="Center"
                                   >
                                                <Label Content="B" 
                                        HorizontalAlignment="Center"/>
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Time (min):" 
                                            HorizontalAlignment="Center"/>
                                                    <Label Content="{Binding scriptEditor.EstimateruntimeforblockB}" 
                                            HorizontalAlignment="Center"/>
                                                </StackPanel >
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Loop" 
                                           HorizontalAlignment="Center"/>
                                                    <TextBox Text="{Binding scriptEditor.ExecuteBlockBLoop}" MinWidth="70"/>
                                                </StackPanel>

                                                <Label Content="Script delay (ms):"/>
                                                <Label Content="{Binding scriptEditor.blockBscriptDelaytime}" />
                                                <Button Command="{Binding scriptEditor.LoadscripttoBlockB }" Height="23" Content="Load"></Button>

                                                <TextBox Text="{Binding scriptEditor.blockBscriptpath, Mode=TwoWay}"
                                         TextWrapping="WrapWithOverflow"
                                         MaxWidth="220" IsReadOnly="True"
                                         />
                                                <Label Content="sequence count : "/>
                                                <Label Content="{Binding scriptEditor.blockBitemcount}"/>
                                            </WrapPanel>
                                        </Grid>
                                        <Grid Grid.Column="2" Margin="5">
                                            <WrapPanel Orientation="Vertical" HorizontalAlignment="Center" >
                                                <Label Content="C" 
                           HorizontalAlignment="Center"/>
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Time (min):" 
                           HorizontalAlignment="Center"/>
                                                    <Label Content="{Binding scriptEditor.EstimateruntimeforblockC}"
                           HorizontalAlignment="Center"/>
                                                </StackPanel >
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Loop" 
                           HorizontalAlignment="Center"/>
                                                    <TextBox Text="{Binding scriptEditor.ExecuteBlockCLoop}" MinWidth="70"/>
                                                </StackPanel>

                                                <Label Content="Script delay (ms):" />
                                                <Label Content="{Binding scriptEditor.blockCscriptDelaytime}" />
                                                <Button Command="{Binding  scriptEditor.LoadscripttoBlockC}" Height="23" Content="Load"></Button>

                                                <TextBox Text="{Binding scriptEditor.blockCscriptpath, Mode=TwoWay}"
                                         TextWrapping="WrapWithOverflow"
                                         MaxWidth="220" IsReadOnly="True"
                                         />
                                                <Label Content="sequence count : "/>
                                                <Label Content="{Binding scriptEditor.blockCitemcount}"/>
                                            </WrapPanel>
                                        </Grid>
                                        <Grid Grid.Column="3" Margin="5">
                                            <WrapPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                <Label Content="D" 
                           HorizontalAlignment="Center"/>
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Time (min):" 
                           HorizontalAlignment="Center"/>
                                                    <Label Content="{Binding scriptEditor.EstimateruntimeforblockD}"
                           HorizontalAlignment="Center"/>
                                                </StackPanel >
                                                <Separator Margin="0 10 0 10"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 5 0 5">
                                                    <Label Content="Loop" 
                           HorizontalAlignment="Center"/>
                                                    <TextBox  Text="{Binding scriptEditor.ExecuteBlockDLoop}" MinWidth="70"/>
                                                </StackPanel>

                                                <Label Content="Script delay (ms):" />
                                                <Label Content="{Binding scriptEditor.blockDscriptDelaytime}" />
                                                <Button Command="{Binding  scriptEditor.LoadscripttoBlockD}" Height="23" Content="Load"></Button>

                                                <TextBox Text="{Binding scriptEditor.blockDscriptpath, Mode=TwoWay}"
                                         TextWrapping="WrapWithOverflow"
                                         MaxWidth="220"  IsReadOnly="True"
                                         />
                                                <Label Content="sequence count : "/>
                                                <Label Content="{Binding scriptEditor.blockDitemcount}"/>
                                            </WrapPanel>
                                        </Grid>


                                    </Grid>

                                </Grid>

                            </ScrollViewer>
                        </Grid>

                        <Expander ExpandDirection="Right" 
                                  Margin="5"
                                  IsExpanded="False"  Grid.Column="1" 
                                  HorizontalAlignment="Left"  
                                  VerticalAlignment="Stretch"
                                  >
                            <Grid MaxWidth="320" >
                                <Grid Grid.Column="0" Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="60"/>
                                        <RowDefinition Height="1*"/>

                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Grid.Column="0" >
                                        <WrapPanel Orientation="Vertical">

                                            <Button MinWidth="280" Height="32" 
                                                Command="{Binding scriptEditor.SettinViewPath}" 
                                                x:Name="menubt_reload"
                                                ToolTip="View the path location" 
                                                HorizontalAlignment="Left" 
                                                Margin="3 0 3 6">

                                                <Button.Style>

                                                    <Style TargetType="{x:Type Button}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type Button}">
                                                                    <ContentControl>
                                                                        <Border Name="innerborder" BorderBrush="Gray" BorderThickness="1.2 .7 1.2 1.8" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                            <Grid>
                                                                                <materialDesign:PackIcon Kind="BookOpenVariant"
                                                                            Width="26" Height="26"
                                                                            VerticalAlignment="Stretch" 
                                                                            Foreground="#FF4D4D4D" 
                                                                            HorizontalAlignment="Stretch"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ContentControl>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="Button.IsPressed" Value="True" >
                                                                            <Setter TargetName="innerborder" Property="BorderBrush" Value="DarkGray" />
                                                                            <Setter TargetName="innerborder" Property="BorderThickness" Value="1" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <TextBox Text="{Binding scriptEditor.Viewerpath}"
                                                 HorizontalAlignment="Center" MinWidth = "280"
                                                 IsReadOnly="True"/>
                                        </WrapPanel>

                                    </Grid>
                                    <Grid Grid.Column="0" Grid.Row="1">
                                        <TreeView Name="trvFamilies" ItemsSource="{Binding scriptEditor.folderViewerlist}"
                                              Grid.Row="1" Grid.ColumnSpan="2"
                                              dd:DragDrop.IsDragSource="True"
                                              dd:DragDrop.IsDropTarget="True"
                                              dd:DragDrop.SelectDroppedItems="True"
                                              dd:DragDrop.UseDefaultDragAdorner="True"
                                              dd:DragDrop.UseDefaultEffectDataTemplate="True"
                                              VerticalAlignment="Stretch"
                                              MinHeight="730" MaxHeight="960"
                                              >

                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="{x:Type TreeViewItem}">
                                                    <Setter Property="IsSelected" Value="{Binding IsSelected}" />
                                                    <Setter Property="IsExpanded" Value="True"/>
                                                </Style>
                                            </TreeView.ItemContainerStyle>
                                            <TreeView.Resources>
                                                <HierarchicalDataTemplate DataType="{x:Type self:Foldertype}" ItemsSource="{Binding Children}" >
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label VerticalAlignment="Center" FontFamily="WingDings" Content="1" FontSize="12"/>
                                                        <TextBlock Text="{Binding FriendlyName}" FontSize="12"/>
                                                    </StackPanel>
                                                </HierarchicalDataTemplate>
                                                <DataTemplate DataType="{x:Type self:IFiletype}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label VerticalAlignment="Center" FontFamily="WingDings" Content="2" FontSize="12"/>
                                                        <TextBlock Text="{Binding FriendlyName}" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </TreeView.Resources>
                                        </TreeView>

                                    </Grid>
                                </Grid>

                            </Grid>
                        </Expander>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
